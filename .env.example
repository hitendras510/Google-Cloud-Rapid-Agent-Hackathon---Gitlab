# =============================================================================
# .env.example — PipelineGuardian environment variable template
# =============================================================================
# Copy to .env for local development:
#   cp .env.example .env
#
# In Cloud Run, these are loaded from Google Cloud Secret Manager automatically.
# NEVER commit your real .env file to version control.
# =============================================================================

# ── Google Cloud ───────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GCP_REGION=asia-south1

# ── Google AI (Gemini) ─────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy-your-key-here
GEMINI_MODEL=gemini-2.5-flash

# ── GitLab ─────────────────────────────────────────────────────────────────────
# PAT scopes required: api, read_repository, write_repository
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_MCP_URL=https://gitlab.com/api/v4/mcp
GITLAB_INSTANCE_URL=https://gitlab.com

# ── Supabase ───────────────────────────────────────────────────────────────────
# From: Supabase Dashboard → Settings → API
SUPABASE_URL=https://bcpeepyeouowchgzwbpu.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Webhook ────────────────────────────────────────────────────────────────────
# This must match the "Secret token" you set in GitLab → Webhooks settings
# Generate one: openssl rand -hex 32
WEBHOOK_SECRET=your-random-secret-here

# ── Local dev only (not used in Cloud Run) ─────────────────────────────────────
PORT=8080
