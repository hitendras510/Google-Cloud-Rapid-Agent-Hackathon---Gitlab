# PipelineGuardian ADK Agent — Environment Variables
# Copy this file to adk_agents/.env and fill in your values.
# Never commit the real .env to version control.

# ── Google AI ─────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-ai-api-key-here
GEMINI_MODEL=gemini-2.5-flash          # or gemini-2.5-flash-preview-05-20

# ── GitLab ────────────────────────────────────────────────────────────────────
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
GITLAB_MCP_URL=https://gitlab.com/api/v4/mcp
GITLAB_INSTANCE_URL=https://gitlab.com   # change for self-hosted instances

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://bcpeepyeouowchgzwbpu.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
